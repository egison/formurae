def u := function (x, y, z)
def feX : [MathValue] := [`(1 + x) * cos y, `(1 + x) * sin y, z]
def feGd (a: Integer) : MathValue := sum (map (\e -> (∂/∂ e feCoords_a) ^ 2) feX)
def feGo (a: Integer) (b: Integer) : MathValue := sum (map (\e -> ∂/∂ e feCoords_a * ∂/∂ e feCoords_b) feX)
