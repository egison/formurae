         ++ [ S.concat ["begin function ", tupleOf comps, " = init()"]
            , S.concat ["  double [] :: ", S.intercalate ", " comps]
            ]
         ++ initLines
         ++ [ "end function"
            , ""
            , S.concat ["begin function ", tupleOf compsP,
                        " = step", "(", S.intercalate "," comps, ")"]
            ]
         ++ stepLines
         ++ [ "end function" ])

def u := function (x, y, z)
def feX : [MathValue] := [`(1 + x) * cos y, `(1 + x) * sin y, z]
def feGd (a: Integer) : MathValue := sum (map (\e -> (∂/∂ e feCoords_a) ^ 2) feX)
def feGo (a: Integer) (b: Integer) : MathValue := sum (map (\e -> ∂/∂ e feCoords_a * ∂/∂ e feCoords_b) feX)
def feH1 := unquoteAll (expandAll (sqrt (feGd 1)))
def feH2 := unquoteAll (expandAll (sqrt (feGd 2)))
def feH3 := unquoteAll (expandAll (sqrt (feGd 3)))
def ca := function (x, y, z)
def cb := function (x, y, z)
def cc := function (x, y, z)
def sg := function (x, y, z)
