-- 2D divergence smoke test using the shared one-line Egison operator.

mode collocated
dimension 2
axes x, y

param dt = 1.0

extern sin
raw sx = fun(x) sin(6.283185307179586*x/(total_grid_x*dx))
raw sy = fun(y) sin(6.283185307179586*y/(total_grid_y*dy))

field V_i
field q : scalar

init:
  V_i = [| sx(i*dx), sy(j*dy) |]_i
  q = 0.0

step:
  V'_i = V_i
  q' = divg V
