dimension :: 1
axes :: x

double :: kappa = 1.0
double :: dt = 0.1*dx*dx

extern function :: exp
gauss = fun(x) exp(-((x-(total_grid_x*dx/2))/(5*dx))**2)

begin function u = init()
  double [] :: u
  u[i] = gauss(i*dx)
end function

begin function u' = step(u)
  u'[i] = u[i] + dt * kappa * (u[i-1] + u[i+1] + (-2) * u[i]) / dx**2
end function
