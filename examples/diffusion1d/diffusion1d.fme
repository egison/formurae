-- The 1D diffusion equation: du/dt = kappa * laplacian(u)

mode collocated
dimension 1
axes x

param κ = 1.0
param dt = 0.1*dx*dx

extern exp
raw gauss = fun(x) exp(-((x-(total_grid_x*dx/2))/(5*dx))**2)

field u : scalar @ primal

init:
  u = gauss(i*dx)

step:
  local q_i @ primal = [| 0 - κ * ∂_x u |]_i
  u' = u - dt * divg q
