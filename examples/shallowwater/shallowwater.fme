-- Shallow water equations in conservation form (h, hu, hv), central
-- differences on the momentum fluxes (locals) plus a small Laplacian
-- viscosity; every piece is in flux form, so mass and momentum
-- telescope exactly.  A 1% bump splits into gravity waves at
-- c = sqrt(g h0) = 1, measured by the check driver.

mode collocated
dimension 3
axes x, y, z

param g = 1.0
param λ = 0.05
param dt = 0.05

extern exp

field h : scalar
field mx : scalar
field my : scalar

init:
  h = 1.0 + 0.01*exp(-((i*dx - 32.0)/2.0)**2)
  mx = 0.0
  my = 0.0

step:
  local fmxx = mx * mx / h + g * h * h / 2
  local fmxy = mx * my / h
  local fmyy = my * my / h + g * h * h / 2
  h' = h - dt * (∂_x mx + ∂_y my) + dt * λ * (∂^2_x h + ∂^2_y h)
  mx' = mx - dt * (∂_x fmxx + ∂_y fmxy) + dt * λ * (∂^2_x mx + ∂^2_y mx)
  my' = my - dt * (∂_x fmxy + ∂_y fmyy) + dt * λ * (∂^2_x my + ∂^2_y my)
