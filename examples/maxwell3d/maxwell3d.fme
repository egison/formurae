-- Maxwell's equations in vacuum (c = 1), collocated grid
--   dE/dt =  curl B
--   dB/dt = -curl E'     (the B update uses the updated E': symplectic)
-- curl is defined directly in the Formurae source using tensor indices.

dimension 3
axes x, y, z

param dt = 0.1*dx

extern exp
raw gauss1 = fun(x) exp(-((x-(total_grid_x*dx/2))/(8*dx))**2)

field E_i
field B_i

def curl X = withSymbols [i] delta_i~1 * (∂_y X_3 - ∂_z X_2) + delta_i~2 * (∂_z X_1 - ∂_x X_3) + delta_i~3 * (∂_x X_2 - ∂_y X_1)

init:
  E_i = [| 0, gauss1(i*dx), 0 |]_i
  B_i = [| 0, 0, gauss1(i*dx) |]_i

step:
  E'_i = E_i + dt * curl B_i
  B'_i = B_i - dt * curl E'_i
