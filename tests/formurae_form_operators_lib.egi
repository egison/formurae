declare symbol x, y, z

def coordinates : Vector MathValue := [|x, y, z|]
def dimension : Integer := 3
def feGeometryScales : Vector MathValue := [|1, 1, 1|]
def feGeometryId : Integer := 1
def epsilon : Tensor Integer := ε dimension
def fePrimitiveManifestId : String :=
  Formurae.Primitives.primitiveManifestV1Id

def formU := function (x, y, z)
def formX1 := function (x, y, z)
def formX2 := function (x, y, z)
def formX3 := function (x, y, z)
def formX := [|formX1, formX2, formX3|]

def formB12 := function (x, y, z)
def formB13 := function (x, y, z)
def formB23 := function (x, y, z)
def formB :=
  FE.canonicalFormTensor
    (\basis ->
      if basis = [1, 2]
        then formB12
        else if basis = [1, 3] then formB13 else formB23)
    3 2

assertEqual "d maps 0-forms to their analytic gradient"
  (FE.formComponents (Formurae.d formU))
  [ userRefs formU [1]
  , userRefs formU [2]
  , userRefs formU [3]
  ]

assertEqual "d uses the normative one-form component signs"
  (FE.formComponents (Formurae.d formX))
  [ userRefs formX2 [1] - userRefs formX1 [2]
  , userRefs formX3 [1] - userRefs formX1 [3]
  , userRefs formX3 [2] - userRefs formX2 [3]
  ]

assertEqual "d uses the normative two-form component signs"
  (FE.formComponents (Formurae.d formB))
  [ userRefs formB23 [1]
    - userRefs formB13 [2]
    + userRefs formB12 [3]
  ]

assertEqual "d squares to zero on a one-form"
  (FE.formComponents
    (Formurae.d (Formurae.d formX)))
  [0]

def formDx := [|1, 0, 0|]
def formDy := [|0, 1, 0|]
def formDz := [|0, 0, 1|]

def formDxy :=
  FE.canonicalFormTensor (\basis -> if basis = [1, 2] then 1 else 0) 3 2
def formDxz :=
  FE.canonicalFormTensor (\basis -> if basis = [1, 3] then 1 else 0) 3 2
def formDyz :=
  FE.canonicalFormTensor (\basis -> if basis = [2, 3] then 1 else 0) 3 2
def formVolume := FE.canonicalFormTensor (\_ -> 1) 3 3

assertEqual "Euclidean Hodge maps degree k to 3-k"
  (map
    (\form ->
      let starred :=
            Formurae.hodge form
       in (dfOrder starred, FE.formComponents starred))
    [1, formDx, formDxy, formVolume])
  [(3, [1]), (2, [0, 0, 1]), (1, [0, 0, 1]), (0, [1])]

assertEqual "Euclidean Hodge one-form basis signs"
  (map
    (\form -> FE.formComponents (Formurae.hodge form))
    [formDx, formDy, formDz])
  [[0, 0, 1], [0, -1, 0], [1, 0, 0]]

assertEqual "Euclidean Hodge two-form basis signs"
  (map
    (\form -> FE.formComponents (Formurae.hodge form))
    [formDxy, formDxz, formDyz])
  [[0, 0, 1], [0, -1, 0], [1, 0, 0]]

assertEqual "Hodge square has the Euclidean orientation sign"
  (FE.formComponents
    (Formurae.hodge (Formurae.hodge formDx)))
  [1, 0, 0]

assertEqual "codifferential of a one-form is negative divergence"
  (Formurae.codiff formX)
  (0 - userRefs formX1 [1]
     - userRefs formX2 [2]
     - userRefs formX3 [3])

assertEqual "codifferential two-form components follow the fixed sign"
  (FE.formComponents
    (Formurae.codiff formB))
  [ userRefs formB12 [2] + userRefs formB13 [3]
  , 0 - userRefs formB12 [1] + userRefs formB23 [3]
  , 0 - userRefs formB13 [1] - userRefs formB23 [2]
  ]

assertEqual "PDE-sign scalar Laplacian is minus codifferential d"
  ( Formurae.scalarLaplacian formU
  , 0 - Formurae.codiff (Formurae.d formU))
  (Formurae.lap formU, Formurae.lap formU)

assertEqual "Hodge Laplacian is d delta plus delta d on a middle-degree form"
  (Formurae.hodgeLaplacian formB)
  ( Formurae.d (Formurae.codiff formB)
    + Formurae.codiff (Formurae.d formB)
  )

assertEqual "Hodge Laplacian omits d delta on a zero-form"
  (Formurae.hodgeLaplacian formU)
  (Formurae.codiff (Formurae.d formU))

assertEqual "Hodge Laplacian omits delta d on a top form"
  (Formurae.hodgeLaplacian formVolume)
  (Formurae.d (Formurae.codiff formVolume))

-- Discrete counterparts used by the generic codifferential macro.  On the
-- flat identity geometry the weighted star coincides with the analytic
-- hodge and the weighted flux is the identity on components, while the
-- discrete exterior derivative antisymmetrizes the placement-directed
-- grid derivative instead of producing analytic jets.
def flatIdentityMetric : Tensor MathValue :=
  generateTensor (\[i, j] -> if i = j then 1 else 0) [3, 3]

assertEqual "flat weighted star matches the analytic hodge on a 1-form"
  (FE.formComponents (Formurae.dHodgeWith 1 flatIdentityMetric formX))
  (FE.formComponents (Formurae.hodge formX))

assertEqual "flat weighted star matches the analytic hodge on a 2-form"
  (FE.formComponents (Formurae.dHodgeWith 1 flatIdentityMetric formB))
  (FE.formComponents (Formurae.hodge formB))

assertEqual "flat weighted flux is the identity on components"
  (FE.formComponents (Formurae.dFluxWith 1 flatIdentityMetric formB))
  (FE.formComponents formB)

assertEqual "discrete exterior derivative antisymmetrizes the grid derivative"
  (FE.formComponents (Formurae.dExterior formX))
  [ Formurae.gridWholeDerivative 1 formX2 - Formurae.gridWholeDerivative 2 formX1
  , Formurae.gridWholeDerivative 1 formX3 - Formurae.gridWholeDerivative 3 formX1
  , Formurae.gridWholeDerivative 2 formX3 - Formurae.gridWholeDerivative 3 formX2
  ]

assertEqual "discrete exterior derivative of a scalar is the grid gradient"
  (FE.formComponents (Formurae.dExterior formU))
  [ Formurae.gridWholeDerivative 1 formU
  , Formurae.gridWholeDerivative 2 formU
  , Formurae.gridWholeDerivative 3 formU
  ]
