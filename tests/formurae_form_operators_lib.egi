declare symbol x, y, z

def formCoordinates3 : Vector MathValue := [|x, y, z|]
def formDimension3 : Integer := 3
def formScales3 : Vector MathValue := [|1, 1, 1|]
def formCoordinates2 : Vector MathValue := [|x, y|]
def formDimension2 : Integer := 2
def formScales2 : Vector MathValue := [|1, 1|]

def formU := function (x, y, z)
def formX1 := function (x, y, z)
def formX2 := function (x, y, z)
def formX3 := function (x, y, z)
def formX := [|formX1, formX2, formX3|]

def formB12 := function (x, y, z)
def formB13 := function (x, y, z)
def formB23 := function (x, y, z)
def formB :=
  FE.canonicalFormTensor
    (\basis ->
      if basis = [1, 2]
        then formB12
        else if basis = [1, 3] then formB13 else formB23)
    3 2

assertEqual "d maps 0-forms to their strict gradient"
  (FE.formComponents (Formurae.d formCoordinates3 formU))
  [ userRefs formU [1]
  , userRefs formU [2]
  , userRefs formU [3]
  ]

assertEqual "d uses the normative one-form component signs"
  (FE.formComponents (Formurae.d formCoordinates3 formX))
  [ userRefs formX2 [1] - userRefs formX1 [2]
  , userRefs formX3 [1] - userRefs formX1 [3]
  , userRefs formX3 [2] - userRefs formX2 [3]
  ]

assertEqual "d uses the normative two-form component signs"
  (FE.formComponents (Formurae.d formCoordinates3 formB))
  [ userRefs formB23 [1]
    - userRefs formB13 [2]
    + userRefs formB12 [3]
  ]

assertEqual "d squares to zero on a one-form"
  (FE.formComponents
    (Formurae.d formCoordinates3
      (Formurae.d formCoordinates3 formX)))
  [0]

def formDx := [|1, 0, 0|]
def formDy := [|0, 1, 0|]
def formDz := [|0, 0, 1|]

def formDxy :=
  FE.canonicalFormTensor (\basis -> if basis = [1, 2] then 1 else 0) 3 2
def formDxz :=
  FE.canonicalFormTensor (\basis -> if basis = [1, 3] then 1 else 0) 3 2
def formDyz :=
  FE.canonicalFormTensor (\basis -> if basis = [2, 3] then 1 else 0) 3 2
def formVolume := FE.canonicalFormTensor (\_ -> 1) 3 3

assertEqual "Euclidean Hodge maps degree k to 3-k"
  (map
    (\form ->
      let starred :=
            Formurae.hodge formDimension3 formScales3 form
       in (dfOrder starred, FE.formComponents starred))
    [1, formDx, formDxy, formVolume])
  [(3, [1]), (2, [0, 0, 1]), (1, [0, 0, 1]), (0, [1])]

assertEqual "Euclidean Hodge one-form basis signs"
  (map
    (\form -> FE.formComponents (Formurae.hodge formDimension3 formScales3 form))
    [formDx, formDy, formDz])
  [[0, 0, 1], [0, -1, 0], [1, 0, 0]]

assertEqual "Euclidean Hodge two-form basis signs"
  (map
    (\form -> FE.formComponents (Formurae.hodge formDimension3 formScales3 form))
    [formDxy, formDxz, formDyz])
  [[0, 0, 1], [0, -1, 0], [1, 0, 0]]

assertEqual "Hodge square has the Euclidean orientation sign"
  (FE.formComponents
    (Formurae.hodge formDimension3 formScales3
      (Formurae.hodge formDimension3 formScales3 formDx)))
  [1, 0, 0]

def formDx2 := [|1, 0|]

def variableFormScales2 : Vector MathValue := [|2, 3|]

def formDy2 := [|0, 1|]

def formArea2 := FE.canonicalFormTensor (\_ -> 1) 2 2

assertEqual "orthogonal Hodge uses volume over source scale squares"
  (map
    (\form -> FE.formComponents (Formurae.hodge formDimension2 variableFormScales2 form))
    [1, formDx2, formDy2, formArea2])
  [[6], [0, 3 / 2], [0 - 2 / 3, 0], [1 / 6]]

assertEqual "orthogonal Hodge square keeps the orientation sign"
  (FE.formComponents
    (Formurae.hodge formDimension2 variableFormScales2
      (Formurae.hodge formDimension2 variableFormScales2 formDx2)))
  [-1, 0]

assertEqual "orthogonal flat is one metric contraction"
  (Formurae.flat formDimension2 variableFormScales2 [|x, y|])
  [|4 * x, 9 * y|]

assertEqual "flat result carries covector metadata"
  (tensorVariances
      (Formurae.flat formDimension2 variableFormScales2 [|x, y|]),
   dfOrder (Formurae.flat formDimension2 variableFormScales2 [|x, y|]))
  (["down"], 0)

assertEqual "orthogonal sharp is one inverse-metric contraction"
  (Formurae.sharp formDimension2 variableFormScales2 [|x, y|])
  [|x / 4, y / 9|]

assertEqual "sharp result carries contravariant vector metadata"
  (tensorVariances
      (Formurae.sharp formDimension2 variableFormScales2 [|x, y|]),
   dfOrder (Formurae.sharp formDimension2 variableFormScales2 [|x, y|]))
  (["up"], 0)

assertEqual "orthogonal musical maps are inverses"
  (Formurae.sharp formDimension2 variableFormScales2
    (Formurae.flat formDimension2 variableFormScales2 [|x, y|]))
  [|x, y|]

assertEqual "two-dimensional Hodge square is negative on one-forms"
  (FE.formComponents
    (Formurae.hodge formDimension2 formScales2
      (Formurae.hodge formDimension2 formScales2 formDx2)))
  [-1, 0]

assertEqual "codifferential of a one-form is negative divergence"
  (Formurae.codiff formCoordinates3 formDimension3 formScales3 formX)
  (0 - userRefs formX1 [1]
     - userRefs formX2 [2]
     - userRefs formX3 [3])

assertEqual "codifferential two-form components follow the fixed sign"
  (FE.formComponents
    (Formurae.codiff formCoordinates3 formDimension3 formScales3 formB))
  [ userRefs formB12 [2] + userRefs formB13 [3]
  , 0 - userRefs formB12 [1] + userRefs formB23 [3]
  , 0 - userRefs formB13 [1] - userRefs formB23 [2]
  ]

assertEqual "PDE-sign scalar Laplacian is minus codifferential d"
  ( Formurae.scalarLaplacian
      formCoordinates3 formDimension3 formScales3 formU
  , 0 - Formurae.codiff formCoordinates3 formDimension3 formScales3
          (Formurae.d formCoordinates3 formU))
  (Formurae.lap formCoordinates3 formU,
   Formurae.lap formCoordinates3 formU)

assertEqual "Hodge Laplacian is d delta plus delta d on a middle-degree form"
  (Formurae.hodgeLaplacian
    formCoordinates3 formDimension3 formScales3 formB)
  ( Formurae.d formCoordinates3
      (Formurae.codiff formCoordinates3 formDimension3 formScales3 formB)
    + Formurae.codiff formCoordinates3 formDimension3 formScales3
        (Formurae.d formCoordinates3 formB)
  )

assertEqual "Hodge Laplacian omits d delta on a zero-form"
  (Formurae.hodgeLaplacian
    formCoordinates3 formDimension3 formScales3 formU)
  (Formurae.codiff formCoordinates3 formDimension3 formScales3
    (Formurae.d formCoordinates3 formU))

assertEqual "Hodge Laplacian omits delta d on a top form"
  (Formurae.hodgeLaplacian
    formCoordinates3 formDimension3 formScales3 formVolume)
  (Formurae.d formCoordinates3
    (Formurae.codiff formCoordinates3 formDimension3 formScales3 formVolume))
