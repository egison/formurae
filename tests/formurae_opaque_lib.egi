declare symbol x, y

def coordinates : Vector MathValue := [|x, y|]
def dimension : Integer := 2
def feGeometryScales : Vector MathValue := [|1, 1|]
def feGeometryId : Integer := 1
def epsilon : Tensor Integer := ε dimension
def fePrimitiveManifestId : String :=
  Formurae.Primitives.primitiveManifestId

def opaqueU := function (x, y)
def opaqueCoordinates := [(x, 1), (y, 2)]
def opaqueFields := [FEIR.fieldEntry 1 "current" [] opaqueU]

def encodeOpaqueFixture value :=
  FEIR.encodeScalar [] opaqueCoordinates opaqueFields [] [] value

def encodedOpaqueU := encodeOpaqueFixture opaqueU

def wideRequest :=
  Formurae.coordinateWideDerivative 2 2 2 opaqueU

def gridWholeOperand := opaqueU * opaqueU / 2

def gridWholeRequest :=
  Formurae.gridWholeDerivative 1 gridWholeOperand

def expectedWide :=
  FEIR.opaqueNode "derivative.coordinate-wide" []
    [FEIR.scalarValue encodedOpaqueU]
    [ FEIR.attribute "order" (FEIR.attributeNatural 2)
    , FEIR.attribute "ordered-axes"
        (FEIR.attributeValues [FEIR.attributeAxis 2])
    , FEIR.attribute "radius" (FEIR.attributeNatural 2)
    ]

def expectedGridWhole :=
  FEIR.opaqueNode "derivative.grid-whole" []
    [FEIR.scalarValue (encodeOpaqueFixture gridWholeOperand)]
    [ FEIR.attribute "order" (FEIR.attributeNatural 1)
    , FEIR.attribute "ordered-axes"
        (FEIR.attributeValues [FEIR.attributeAxis 1])
    , FEIR.attribute "radius" (FEIR.attributeNatural 1)
    ]

assertEqual "wide derivative preserves ordered axis, order, and radius"
  (FEIR.render (encodeOpaqueFixture wideRequest))
  (FEIR.render expectedWide)

assertEqual "grid-whole derivative preserves one nonlinear operand"
  (FEIR.render (encodeOpaqueFixture gridWholeRequest))
  (FEIR.render expectedGridWhole)

assertEqual "grid-whole differs from analytic product-rule differentiation"
  (encodeOpaqueFixture gridWholeRequest
    = encodeOpaqueFixture
        (partialDiffMV gridWholeOperand x))
  False

assertEqual "opaque semantic key and request group are deterministic"
  (encodeOpaqueFixture
    (Formurae.gridWholeDerivative 1 gridWholeOperand))
  (encodeOpaqueFixture gridWholeRequest)

assertEqual "ordinary algebra retains opaque atoms"
  (FEIR.render (encodeOpaqueFixture (2 * gridWholeRequest + wideRequest)))
  (FEIR.render
    (FEIR.addNode
      [ FEIR.mulNode [FEIR.exactInteger 2, expectedGridWhole]
      , expectedWide
      ]))

assertEqual "explicit radius is part of wide semantic identity"
  (encodeOpaqueFixture wideRequest
    = encodeOpaqueFixture
        (Formurae.coordinateWideDerivative 2 2 3 opaqueU))
  False
