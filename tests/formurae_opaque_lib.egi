declare symbol x, y

def opaqueDimension : Integer := 2
def opaqueGeometryId : Integer := 1
def opaqueOtherGeometryId : Integer := 2
def opaqueManifestId : String :=
  Formurae.Primitives.primitiveManifestV1Id

def opaqueU := function (x, y)
def opaqueCoordinates := [(x, 1), (y, 2)]
def opaqueFields := [FEIR.fieldEntry 1 "current" [] opaqueU]

def opaqueA1 := function (x, y)
def opaqueA2 := function (x, y)
def opaqueA :=
  FE.canonicalFormTensor
    (\basis -> if basis = [1] then opaqueA1 else opaqueA2) 2 1
def opaqueMetricFields :=
  [ FEIR.fieldEntry 2 "current" [1] opaqueA1
  , FEIR.fieldEntry 2 "current" [2] opaqueA2
  ]
def encodeOpaqueFixture value :=
  FEIR.encodeScalar [] opaqueCoordinates opaqueFields [] [] value

def encodedOpaqueU := encodeOpaqueFixture opaqueU

def lbRequest :=
  Formurae.lbOrthogonal opaqueGeometryId opaqueManifestId opaqueU

def wideRequest :=
  Formurae.coordinateWideDerivative
    opaqueDimension opaqueManifestId 2 2 2 opaqueU

def gridWholeOperand := opaqueU * opaqueU / 2

def gridWholeRequest :=
  Formurae.gridWholeDerivative
    opaqueDimension opaqueManifestId 1 gridWholeOperand

def metricCodiffRequest :=
  FE.tensorComponentAt
    (Formurae.metricCodiff
      opaqueDimension opaqueGeometryId opaqueManifestId opaqueA) []

def expectedLb :=
  FEIR.opaqueNode "lb.orthogonal@1" []
    [FEIR.scalarValue encodedOpaqueU]
    [ FEIR.attribute "metric" (FEIR.attributeGeometry 1)
    , FEIR.attribute "source-policy"
        (FEIR.attributeGridPolicy "collocated")
    ]

def expectedWide :=
  FEIR.opaqueNode "derivative.coordinate-wide@1" []
    [FEIR.scalarValue encodedOpaqueU]
    [ FEIR.attribute "order" (FEIR.attributeNatural 2)
    , FEIR.attribute "ordered-axes"
        (FEIR.attributeValues [FEIR.attributeAxis 2])
    , FEIR.attribute "radius" (FEIR.attributeNatural 2)
    ]

def expectedGridWhole :=
  FEIR.opaqueNode "derivative.grid-whole@1" []
    [FEIR.scalarValue (encodeOpaqueFixture gridWholeOperand)]
    [ FEIR.attribute "order" (FEIR.attributeNatural 1)
    , FEIR.attribute "ordered-axes"
        (FEIR.attributeValues [FEIR.attributeAxis 1])
    , FEIR.attribute "radius" (FEIR.attributeNatural 1)
    ]

def expectedMetricCodiff :=
  FEIR.opaqueNode "codiff.metric@1" []
    [ FEIR.tensorValue
        (FEIR.encodeTensorValues [] opaqueCoordinates opaqueMetricFields [] []
          2 1 (tensorToList opaqueA))
    ]
    [ FEIR.attribute "metric" (FEIR.attributeGeometry 1)
    , FEIR.attribute "dimension" (FEIR.attributeNatural 2)
    , FEIR.attribute "source-degree" (FEIR.attributeNatural 1)
    ]

assertEqual "lb reserved FunctionData encodes as manifest-backed OpaqueDiscrete"
  (FEIR.render (encodeOpaqueFixture lbRequest))
  (FEIR.render expectedLb)

assertEqual "wide derivative preserves ordered axis, order, and radius"
  (FEIR.render (encodeOpaqueFixture wideRequest))
  (FEIR.render expectedWide)

assertEqual "grid-whole derivative preserves one nonlinear operand"
  (FEIR.render (encodeOpaqueFixture gridWholeRequest))
  (FEIR.render expectedGridWhole)

assertEqual "variable-metric codifferential keeps the complete form opaque"
  (FEIR.render
    (FEIR.encodeScalar [] opaqueCoordinates opaqueMetricFields [] []
      metricCodiffRequest))
  (FEIR.render expectedMetricCodiff)

assertEqual "grid-whole differs from analytic product-rule differentiation"
  (encodeOpaqueFixture gridWholeRequest
    = encodeOpaqueFixture
        (strictPartialDiffMV gridWholeOperand x))
  False

assertEqual "opaque semantic key and request group are deterministic"
  (encodeOpaqueFixture
    (Formurae.lbOrthogonal opaqueGeometryId opaqueManifestId opaqueU))
  (encodeOpaqueFixture lbRequest)

assertEqual "ordinary algebra retains opaque atoms"
  (FEIR.render (encodeOpaqueFixture (2 * lbRequest + wideRequest)))
  (FEIR.render
    (FEIR.addNode
      [ FEIR.mulNode [FEIR.exactInteger 2, expectedLb]
      , expectedWide
      ]))

assertEqual "geometry ID is part of lb semantic identity"
  (encodeOpaqueFixture lbRequest
    = encodeOpaqueFixture
        (Formurae.lbOrthogonal
          opaqueOtherGeometryId opaqueManifestId opaqueU))
  False

assertEqual "explicit radius is part of wide semantic identity"
  (encodeOpaqueFixture wideRequest
    = encodeOpaqueFixture
        (Formurae.coordinateWideDerivative
          opaqueDimension opaqueManifestId 2 2 3 opaqueU))
  False
