declare symbol x, y

def coordinates : Vector MathValue := [|x, y|]
def dimension : Integer := 2
def feGeometryScales : Vector MathValue := [|2, 3|]
def feGeometryId : Integer := 1
def epsilon : Tensor Integer := ε dimension
def fePrimitiveManifestId : String :=
  Formurae.Primitives.primitiveManifestId

def formDx := [|1, 0|]
def formDy := [|0, 1|]
def formArea := FE.canonicalFormTensor (\_ -> 1) 2 2

assertEqual "orthogonal Hodge uses volume over source scale squares"
  (map
    (\form -> FE.formComponents (Formurae.hodge form))
    [1, formDx, formDy, formArea])
  [[6], [0, 3 / 2], [0 - 2 / 3, 0], [1 / 6]]

assertEqual "orthogonal Hodge square keeps the orientation sign"
  (FE.formComponents (Formurae.hodge (Formurae.hodge formDx)))
  [-1, 0]
