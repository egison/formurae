declare symbol x

def wholeFieldPrinterContext :=
  ([], [], ["i", "j", "k"], [|x, x, x|], [|1, 1, 1|], [1, 2, 3])

def symbolicCallPrinterContext :=
  ([],
   [("A_1_1", "A_up1_down1"), ("A_2_2", "A_up2_down2")],
   ["i", "j"], [|x, x|], [|1, 1|], [1, 2])

def symbolicCallA11 := functionSymbol "A_1_1" [x, x]
def symbolicCallA22 := functionSymbol "A_2_2" [x, x]

assertEqual
  "FunctionData printer distinguishes fields from symbolic backend calls"
  (FMR.show symbolicCallPrinterContext
    (FE.symbolicBinary "max" symbolicCallA11 symbolicCallA22))
  "max(A_up1_down1[i,j],A_up2_down2[i,j])"

assertEqual
  "canonical descriptor projections cover every field layout"
  [ FMR.canonicalFieldProjection "scalar" []
  , FMR.canonicalFieldProjection "vector" [3]
  , FMR.canonicalFieldProjection "symmetric" [3, 3]
  , FMR.canonicalFieldProjection "antisymmetric" [3, 3]
  , FMR.canonicalFieldProjection "full" [2, 2]
  , FMR.canonicalFieldProjection "form" [3, 3]
  ]
  [ [[]]
  , [[1], [2], [3]]
  , [[1, 1], [2, 2], [3, 3], [1, 2], [1, 3], [2, 3]]
  , [[1, 2], [1, 3], [2, 3]]
  , [[1, 1], [1, 2], [2, 1], [2, 2]]
  , [[1, 2], [1, 3], [2, 3]]
  ]

def scalarDescriptor :=
  ("q", Collocated, [], [], "scalar", [[]], [([], "q")])

def vectorDescriptor :=
  ("V", Dual, [3], ["down"], "vector",
   [[1], [2], [3]],
   [([1], "V_down1"), ([2], "V_down2"), ([3], "V_down3")])

def symmetricDescriptor :=
  ("S", Collocated, [3, 3], ["down", "down"], "symmetric",
   [[1, 1], [2, 2], [3, 3], [1, 2], [1, 3], [2, 3]],
   [ ([1, 1], "S_down1_down1"), ([2, 2], "S_down2_down2")
   , ([3, 3], "S_down3_down3"), ([1, 2], "S_down1_down2")
   , ([1, 3], "S_down1_down3"), ([2, 3], "S_down2_down3")
   ])

def antisymmetricDescriptor :=
  ("A", Primal, [3, 3], ["up", "down"], "antisymmetric",
   [[1, 2], [1, 3], [2, 3]],
   [ ([1, 2], "A_up1_down2"), ([1, 3], "A_up1_down3")
   , ([2, 3], "A_up2_down3")
   ])

def fullDescriptor :=
  ("M", Collocated, [2, 2], ["up", "down"], "full",
   [[1, 1], [1, 2], [2, 1], [2, 2]],
   [ ([1, 1], "M_up1_down1"), ([1, 2], "M_up1_down2")
   , ([2, 1], "M_up2_down1"), ([2, 2], "M_up2_down2")
   ])

def formDescriptor :=
  ("omega", Dual, [3, 3], ["down", "down"], "form",
   [[1, 2], [1, 3], [2, 3]],
   [ ([1, 2], "omega_down1_down2"), ([1, 3], "omega_down1_down3")
   , ([2, 3], "omega_down2_down3")
   ])

def symmetricValue := generateTensor (\[i, j] -> 10 * i + j) [3, 3]
def antisymmetricValue :=
  FE.canonicalFormTensor
    (\[i, j] -> if i = 1 then 10 + j else 20 + j)
    3 2
def fullValue := generateTensor (\[i, j] -> 10 * i + j) [2, 2]
def formValue :=
  FE.canonicalFormTensor
    (\[i, j] -> if i = 1 then 100 + j else 200 + j)
    3 2

assertEqual
  "field descriptor derives unprimed and primed function-symbol mappings"
  (FMR.fieldNameMappings vectorDescriptor)
  [ ("V_1", "V_down1"), ("V'_1", "V_down1'")
  , ("V_2", "V_down2"), ("V'_2", "V_down2'")
  , ("V_3", "V_down3"), ("V'_3", "V_down3'")
  ]

assertEqual
  "field equations project scalar and vector descriptors to storage names"
  (FMR.fieldEqs wholeFieldPrinterContext scalarDescriptor
                (Collocated, generateTensor (\[] -> 9) [])
   ++ FMR.fieldEqs wholeFieldPrinterContext vectorDescriptor
                   (Dual, [|1, 2, 3|]))
  [ "  q' = 9"
  , "  V_down1' = 1", "  V_down2' = 2", "  V_down3' = 3"
  ]

assertEqual
  "field equations use symmetric independent-component order"
  (FMR.fieldEqs wholeFieldPrinterContext symmetricDescriptor
                (Collocated, symmetricValue))
  [ "  S_down1_down1' = 11", "  S_down2_down2' = 22"
  , "  S_down3_down3' = 33", "  S_down1_down2' = 12"
  , "  S_down1_down3' = 13", "  S_down2_down3' = 23"
  ]

assertEqual
  "field equations use antisymmetric independent-component order"
  (FMR.fieldEqs wholeFieldPrinterContext antisymmetricDescriptor
                (Primal, antisymmetricValue))
  [ "  A_up1_down2' = 12", "  A_up1_down3' = 13"
  , "  A_up2_down3' = 23"
  ]

assertEqual
  "field equations use row-major full rank-two order"
  (FMR.fieldEqs wholeFieldPrinterContext fullDescriptor
                (Collocated, fullValue))
  [ "  M_up1_down1' = 11", "  M_up1_down2' = 12"
  , "  M_up2_down1' = 21", "  M_up2_down2' = 22"
  ]

assertEqual
  "field equations use canonical form projection order"
  (FMR.fieldEqs wholeFieldPrinterContext formDescriptor (Dual, formValue))
  [ "  omega_down1_down2' = 102", "  omega_down1_down3' = 103"
  , "  omega_down2_down3' = 203"
  ]

assertEqual
  "field initializers reuse unprimed descriptor storage mappings"
  (FMR.fieldInits wholeFieldPrinterContext vectorDescriptor
                  (Dual, [|4, 5, 6|]))
  [ "  V_down1[i,j,k] = 4", "  V_down2[i,j,k] = 5"
  , "  V_down3[i,j,k] = 6"
  ]
