assertEqual "generated primitive manifest ID"
  "sha256:f4623af0a5cebbf8ce86d8871b52335ae8ae7db95eaa0f25224d9bad35512c3b"
  Formurae.Primitives.primitiveManifestV1Id

assertEqual "generated primitive operation IDs"
  [ "codiff.metric@1"
  , "derivative.coordinate-wide@1"
  , "derivative.grid-whole@1"
  , "derivative.ordered@1"
  , "lb.orthogonal@1"
  , "resample.explicit@1"
  ]
  Formurae.Primitives.operationIds

assertEqual "generated full primitive signatures"
  [ ("codiff.metric@1", "codiff.metric", 1, ["form"], "form", "dual-adjoint",
      "needs-materialization", ["coefficient", "flux", "result", "volume"],
      "ordered")
  , ("derivative.coordinate-wide@1", "derivative.coordinate-wide", 1,
      ["scalar"], "scalar",
      "derivative-target", "pure-local", [], "ordered")
  , ("derivative.grid-whole@1", "derivative.grid-whole", 1,
      ["scalar"], "scalar",
      "derivative-target", "pure-local", [], "ordered")
  , ("derivative.ordered@1", "derivative.ordered", 1,
      ["scalar"], "scalar",
      "derivative-target", "pure-local", [], "ordered")
  , ("lb.orthogonal@1", "lb.orthogonal", 1, ["scalar"], "scalar",
      "conservative-cell",
      "needs-materialization", ["coefficient", "flux", "result", "volume"],
      "declared-commutative")
  , ("resample.explicit@1", "resample.explicit", 1,
      ["scalar"], "scalar", "explicit-target",
      "pure-local", [], "ordered")
  ]
  Formurae.Primitives.signatures

assertEqual "every generated operation ID resolves to one signature"
  Formurae.Primitives.operationIds
  (map
    (\operationId ->
      Formurae.Primitives.signatureOperationId
        (Formurae.Primitives.signatureFor operationId))
    Formurae.Primitives.operationIds)
