assertEqual "generated primitive manifest ID"
  "sha256:b7a05af81f6418b2163bd3ef280d911d6409564da41c96d455b872e62d120098"
  Formurae.Primitives.primitiveManifestId

assertEqual "generated primitive operation IDs"
  [ "derivative.coordinate-wide"
  , "derivative.grid-whole"
  , "derivative.ordered"
  , "resample.explicit"
  ]
  Formurae.Primitives.operationIds

assertEqual "generated full primitive signatures"
  [ ("derivative.coordinate-wide", "derivative.coordinate-wide",
      ["scalar"], "scalar",
      "derivative-target", "pure-local", [], "ordered")
  , ("derivative.grid-whole", "derivative.grid-whole",
      ["scalar"], "scalar",
      "derivative-target", "pure-local", [], "ordered")
  , ("derivative.ordered", "derivative.ordered",
      ["scalar"], "scalar",
      "derivative-target", "pure-local", [], "ordered")
  , ("resample.explicit", "resample.explicit",
      ["scalar"], "scalar", "explicit-target",
      "pure-local", [], "ordered")
  ]
  Formurae.Primitives.signatures

assertEqual "every generated operation ID resolves to one signature"
  Formurae.Primitives.operationIds
  (map
    (\operationId ->
      Formurae.Primitives.signatureOperationId
        (Formurae.Primitives.signatureFor operationId))
    Formurae.Primitives.operationIds)
