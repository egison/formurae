declare symbol x

def coordinates : Vector MathValue := [|x|]
def dimension : Integer := 1
def feGeometryScales : Vector MathValue := [|1|]
def feGeometryId : Integer := 1
def epsilon : Tensor Integer := ε dimension
def fePrimitiveManifestId : String :=
  Formurae.Primitives.primitiveManifestId

def opaqueErrorU := function (x)

partialDiffMV
  (Formurae.gridWholeDerivative 1 opaqueErrorU)
  x
