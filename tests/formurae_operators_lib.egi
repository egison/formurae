declare symbol x, y, z

def coordinates : Vector MathValue := [|x, y, z|]
def dimension : Integer := 3
def feGeometryScales : Vector MathValue := [|1, 1, 1|]
def feGeometryId : Integer := 1
def epsilon : Tensor Integer := ε dimension
def fePrimitiveManifestId : String :=
  Formurae.Primitives.primitiveManifestV1Id

assertEqual "ambient operator inputs are ordinary bindings"
  (coordinates, dimension, feGeometryScales)
  ([|x, y, z|], 3, [|1, 1, 1|])

def u := function (x, y, z)
def X1 := function (x, y, z)
def X2 := function (x, y, z)
def X3 := function (x, y, z)
def X := [|X1, X2, X3|]

assertEqual "analytic gradient"
  (Formurae.grad u)
  [|userRefs u [1], userRefs u [2], userRefs u [3]|]

assertEqual "gradient result carries covariant vector metadata"
  (tensorVariances (Formurae.grad u),
   dfOrder (Formurae.grad u))
  (["down"], 0)

assertEqual "analytic vector gradient"
  (Formurae.dGrad X)
  [| [|userRefs X1 [1], userRefs X2 [1], userRefs X3 [1]|]
   , [|userRefs X1 [2], userRefs X2 [2], userRefs X3 [2]|]
   , [|userRefs X1 [3], userRefs X2 [3], userRefs X3 [3]|] |]

assertEqual "vector gradient carries derivative and operand variances"
  (tensorVariances (Formurae.dGrad X),
   dfOrder (Formurae.dGrad X))
  (["down", "down"], 0)

assertEqual "vector gradient preserves a contravariant operand axis"
  (let XUp := Formurae.attachExplicitVariances ["up"] X
    in (tensorVariances (Formurae.dGrad XUp),
        dfOrder (Formurae.dGrad XUp)))
  (["down", "up"], 0)

assertEqual "analytic divergence"
  (Formurae.divg X)
  (userRefs X1 [1] + userRefs X2 [2] + userRefs X3 [3])

assertEqual "analytic curl"
  (Formurae.curl X)
  [| userRefs X3 [2] - userRefs X2 [3]
   , userRefs X1 [3] - userRefs X3 [1]
   , userRefs X2 [1] - userRefs X1 [2] |]

assertEqual "curl result carries covariant vector metadata"
  (tensorVariances
      (Formurae.curl X),
   dfOrder (Formurae.curl X))
  (["down"], 0)

assertEqual "analytic Hessian"
  (Formurae.hessian u)
  [| [|userRefs u [1, 1], userRefs u [1, 2], userRefs u [1, 3]|]
   , [|userRefs u [1, 2], userRefs u [2, 2], userRefs u [2, 3]|]
   , [|userRefs u [1, 3], userRefs u [2, 3], userRefs u [3, 3]|] |]

assertEqual "Hessian result carries covariant rank-two metadata"
  (tensorVariances (Formurae.hessian u),
   dfOrder (Formurae.hessian u))
  (["down", "down"], 0)

assertEqual "analytic Laplacian"
  (Formurae.lap u)
  (userRefs u [1, 1] + userRefs u [2, 2] + userRefs u [3, 3])

assertEqual "Laplacian is divergence of gradient"
  (Formurae.lap u)
  (Formurae.divg (Formurae.grad u))

assertEqual "exterior derivative of a scalar is its gradient"
  (Formurae.d u)
  (Formurae.grad u)

assertEqual "exterior derivative retains an anonymous form axis"
  (tensorVariances (Formurae.d u),
   dfOrder (Formurae.d u))
  ([], 1)

assertEqual "exterior derivative uses the standard one-form convention"
  (Formurae.d X)
  [| [| 0, userRefs X2 [1] - userRefs X1 [2],
            userRefs X3 [1] - userRefs X1 [3] |]
   , [| userRefs X1 [2] - userRefs X2 [1], 0,
         userRefs X3 [2] - userRefs X2 [3] |]
   , [| userRefs X1 [3] - userRefs X3 [1],
         userRefs X2 [3] - userRefs X3 [2], 0 |] |]

assertEqual "exterior derivative squares to zero"
  (Formurae.d (Formurae.d u))
  [| [|0, 0, 0|], [|0, 0, 0|], [|0, 0, 0|] |]
