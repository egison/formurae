declare symbol i, j, k
def v := [|1, 2, 3|]
def w := [|4, 5, 6|]
def m := [|[|1, 2, 3|], [|4, 5, 6|], [|7, 8, 9|]|]
def vi_i := [|1, 2, 3|]
def vi := vi_i
assertEqual "bare-alias-component" vi_2 2
def inner2 (a: Tensor Integer) (b: Tensor Integer) : Integer :=
  withSymbols [i] foldl1 (+) (contract (a~i * b_i))
assertEqual "outer" (outer v w) [|[|4, 5, 6|], [|8, 10, 12|], [|12, 15, 18|]|]
assertEqual "inner" (inner v w) 32
assertEqual "inner2" (inner2 v w) 32
assertEqual "trace" (trace m) 15
assertEqual "matmul" (matmul m m) [|[|30, 36, 42|], [|66, 81, 96|], [|102, 126, 150|]|]
assertEqual "sym" (sym m) [|[|1, 3, 5|], [|3, 5, 7|], [|5, 7, 9|]|]
