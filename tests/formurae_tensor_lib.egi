declare symbol i, j, k, x, y, z
def m := [|[|1, 2, 3|], [|4, 5, 6|], [|7, 8, 9|]|]
def vi_i := [|1, 2, 3|]
def vi := vi_i
assertEqual "bare-alias-component" vi_2 2
assertEqual "trace" (trace m) 15
assertEqual "sym" (sym m) [|[|1, 3, 5|], [|3, 5, 7|], [|5, 7, 9|]|]

-- The mock derivative encodes all four callback arguments, so these assertions
-- test target/source component bases, derivative axes, and contraction
-- signs independently.
def testTensorDerivative
      (targetBasis: [Integer]) (derivativeAxes: [Integer])
      (sourceBasis: [Integer]) (value: MathValue) : MathValue :=
  1000 * sum targetBasis
  + 100 * sum derivativeAxes
  + 10 * sum sourceBasis
  + value

def testGradOperator := FE.grad testTensorDerivative [1, 2]

assertEqual "native operator supports a user-style binding"
  (testGradOperator 7)
  [|1107, 2207|]

assertEqual "native grad"
  (FE.grad testTensorDerivative [1, 2, 3] 7)
  [|1107, 2207, 3307|]

assertEqual "native grad maps component positions to axis identifiers"
  (FE.grad testTensorDerivative [4, 7] 1)
  [|1401, 2701|]

assertEqual "native derivative gradient"
  (FE.dGrad testTensorDerivative [1, 2] [|3, 4|])
  [|[|2113, 3124|], [|3213, 4224|]|]

assertEqual "native divergence"
  (FE.divg testTensorDerivative [1, 2] [|3, 4|])
  337

assertEqual "native curl"
  (FE.curl testTensorDerivative [1, 2, 3] [|3, 4, 5|])
  [|-89, 178, -89|]

assertEqual "native hessian"
  (FE.hessian testTensorDerivative [1, 2] 3)
  [|[|2203, 3303|], [|3303, 4403|]|]

assertEqual "native laplacian passes repeated derivative axes together"
  (FE.lap testTensorDerivative [1, 2] 3)
  606

assertEqual "native operator tensor signatures"
  (map (\t -> (tensorSignature t, dfOrder t))
       [ FE.grad testTensorDerivative [1, 2] 0
       , FE.dGrad testTensorDerivative [1, 2] [|0, 0|]
       , FE.curl testTensorDerivative [1, 2, 3] [|0, 0, 0|]
       , FE.hessian testTensorDerivative [1, 2] 0
       ])
  [ (([2], []), 1)
  , (([2, 2], []), 2)
  , (([3], []), 1)
  , (([2, 2], []), 2)
  ]

def form0 := FE.canonicalFormTensor (\[] -> function (x, y, z)) 3 0
def form1Basis := generateTensor (\[i] -> function (x, y, z)) [3]
def form1 := FE.canonicalFormTensor (FE.tensorComponentAt form1Basis) 3 1
def form2Basis := generateTensor (\[i, j] -> function (x, y, z)) [3, 3]
def form2 := FE.canonicalFormTensor (FE.tensorComponentAt form2Basis) 3 2
def form3Basis := generateTensor (\[i, j, k] -> function (x, y, z)) [3, 3, 3]
def form3 := FE.canonicalFormTensor (FE.tensorComponentAt form3Basis) 3 3

assertEqual "canonical form tensor shapes and inferred degrees"
  (map (\t -> (tensorShape t, dfOrder t)) [form0, form1, form2, form3])
  [([], 0), ([3], 1), ([3, 3], 2), ([3, 3, 3], 3)]

assertEqual "independent component counts follow binomial coefficients"
  (map (\t -> length (FE.formComponents t)) [form0, form1, form2, form3])
  [1, 3, 3, 1]

assertEqual "canonical two-form permutations and diagonal"
  [form2_1_1, form2_1_2, form2_2_1, form2_1_3, form2_3_1,
   form2_2_3, form2_3_2, form2_3_3]
  [0, form2Basis_1_2, -form2Basis_1_2,
   form2Basis_1_3, -form2Basis_1_3,
   form2Basis_2_3, -form2Basis_2_3, 0]

assertEqual "independent form component projection"
  (FE.formComponents form2)
  [form2Basis_1_2, form2Basis_1_3, form2Basis_2_3]

assertEqual "three-form shares one canonical component"
  [form3_1_2_3, form3_2_3_1, form3_2_1_3, form3_1_1_2]
  [form3Basis_1_2_3, form3Basis_1_2_3, -form3Basis_1_2_3, 0]
