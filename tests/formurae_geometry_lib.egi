declare symbol x, y

def testScale (axis: Integer) : MathValue := nth axis [2, 3]

assertEqual "form basis orientation and complement"
  (FE.formBasisSign [1, 2], FE.formBasisSign [2, 1],
   FE.formBasisSign [1, 1], FE.complementFormBasis 3 [1, 3])
  (1, -1, 0, [2])

assertEqual "orthogonal volume and Hodge coefficients"
  (FE.orthogonalVolume [1, 2] testScale,
   map (FE.orthogonalHodgeCoefficient [1, 2] testScale)
       [[], [1], [2], [1, 2]])
  (6, [6, 3 / 2, 2 / 3, 1 / 6])

assertEqual "metric tensors are constructed by shared geometry helpers"
  (FE.metricTensor 2 (FE.inducedMetric [|x, y|] [2 * x, 3 * y]),
   FE.diagonalMetricTensor 2 testScale,
   FE.inverseDiagonalMetricTensor 2 testScale)
  ([|[|4, 0|], [|0, 9|]|],
   [|[|4, 0|], [|0, 9|]|],
   [|[|1 / 4, 0|], [|0, 1 / 9|]|])
